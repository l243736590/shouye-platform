.shouye-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  height: calc(104rpx + env(safe-area-inset-bottom));
  padding: 10rpx 18rpx env(safe-area-inset-bottom);
  background: #fffdf7;
  border-top: 1rpx solid rgba(36, 43, 46, 0.08);
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #687174;
  font-size: 23rpx;
  font-weight: 850;
}

.tab-item.active {
  color: #242b2e;
}

.tab-label {
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
}

.post-tab {
  align-items: center;
}

.ask-tab {
  align-items: center;
}

.post-pill {
  width: 128rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 22rpx;
  background: #c99a2e;
  color: #fffdf7;
  text-align: center;
  font-size: 24rpx;
  font-weight: 950;
  box-shadow: 0 12rpx 28rpx rgba(201, 154, 46, 0.32);
}

.ask-pill {
  background: #e34c5b;
  box-shadow: 0 12rpx 28rpx rgba(227, 76, 91, 0.28);
}
