<view class="shouye-tabbar" wx:if="{{visible}}">
  <view
    class="tab-item {{selected === index ? 'active' : ''}} {{item.isPost ? 'post-tab' : ''}} {{item.isAsk ? 'ask-tab' : ''}}"
    wx:for="{{list}}"
    wx:key="key"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="post-pill ask-pill" wx:if="{{item.isAsk}}">{{item.text}}</view>
    <view class="post-pill" wx:elif="{{item.isPost}}">{{item.text}}</view>
    <view class="tab-label" wx:else>{{item.text}}</view>
  </view>
</view>
