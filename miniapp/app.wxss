page {
  min-height: 100%;
  background: #f4f7f1;
  color: #242b2e;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx 44rpx;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.brand-logo {
  width: 116rpx;
  height: 64rpx;
  object-fit: contain;
}

.brand-title {
  display: block;
  color: #242b2e;
  font-size: 22rpx;
  font-weight: 800;
}

.brand-subtitle {
  display: block;
  color: #697476;
  font-size: 20rpx;
  margin-top: 2rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #242b2e;
  color: #fffdf7;
  font-size: 24rpx;
  font-weight: 800;
}

.pill.light {
  background: #fffdf7;
  color: #242b2e;
  border: 1rpx solid rgba(36, 43, 46, 0.14);
}

.section {
  margin-top: 34rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.eyebrow {
  display: block;
  color: #ed573b;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.h1 {
  display: block;
  margin-top: 6rpx;
  color: #242b2e;
  font-size: 52rpx;
  font-weight: 950;
  line-height: 1.05;
  letter-spacing: 0;
}

.h2 {
  display: block;
  color: #242b2e;
  font-size: 38rpx;
  font-weight: 950;
  line-height: 1.15;
}

.muted {
  color: #657274;
}

.card {
  border-radius: 22rpx;
  background: #fffdf7;
  border: 1rpx solid rgba(36, 43, 46, 0.1);
  box-shadow: 0 18rpx 44rpx rgba(36, 43, 46, 0.08);
}

.dark-card {
  border-radius: 22rpx;
  background: #242b2e;
  color: #fffdf7;
}

.input,
.textarea,
.select-row {
  width: 100%;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #fffdf7;
  border: 1rpx solid rgba(36, 43, 46, 0.16);
  color: #242b2e;
  font-size: 28rpx;
}

.textarea {
  min-height: 220rpx;
  padding-top: 22rpx;
}

.primary-button {
  width: 100%;
  min-height: 92rpx;
  border-radius: 18rpx;
  background: #242b2e;
  color: #fffdf7;
  font-size: 30rpx;
  font-weight: 900;
}

.secondary-button {
  width: 100%;
  min-height: 86rpx;
  border-radius: 18rpx;
  background: #fffdf7;
  color: #242b2e;
  border: 1rpx solid rgba(36, 43, 46, 0.16);
  font-size: 28rpx;
  font-weight: 900;
}

.red {
  background: #d82f3f;
  color: #fffdf7;
}

.gold {
  background: #c99b2b;
  color: #fffdf7;
}

.deep {
  background: #242b2e;
  color: #fffdf7;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(36, 43, 46, 0.06);
  color: #344043;
  font-size: 22rpx;
  font-weight: 800;
}

.tag.gold-tag {
  background: rgba(201, 155, 43, 0.14);
  color: #7a5b08;
}

.meta {
  color: #687174;
  font-size: 22rpx;
  font-weight: 700;
}

.empty {
  padding: 40rpx 28rpx;
  text-align: center;
  color: #687174;
}

.feed-page {
  min-height: 100vh;
  padding: 0 14rpx 132rpx;
  background: #fffdf7;
}

.feed-top {
  position: sticky;
  top: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 96rpx 1fr 96rpx;
  align-items: center;
  min-height: 104rpx;
  padding: 8rpx 10rpx;
  background: rgba(255, 253, 247, 0.96);
  border-bottom: 1rpx solid rgba(36, 43, 46, 0.08);
}

.feed-menu,
.feed-search {
  color: #242b2e;
  font-size: 44rpx;
  font-weight: 400;
}

.feed-tabs {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 46rpx;
}

.feed-tab {
  position: relative;
  color: #8a8f91;
  font-size: 34rpx;
  font-weight: 850;
}

.feed-tab.active {
  color: #242b2e;
}

.feed-tab.active::after {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: -14rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #d82f3f;
}

.feed-benefit {
  min-height: 60rpx;
  border-radius: 999rpx;
  background: #242b2e;
  color: #fffdf7;
  font-size: 22rpx;
  font-weight: 900;
}

.feed-cats {
  width: 100%;
  padding: 18rpx 10rpx 16rpx;
  white-space: nowrap;
  border-bottom: 1rpx solid rgba(36, 43, 46, 0.06);
}

.feed-cat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 58rpx;
  margin-right: 24rpx;
  color: #777f81;
  font-size: 29rpx;
  font-weight: 800;
}

.feed-cat.active {
  color: #242b2e;
  font-weight: 950;
}

.feed-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx;
  padding-top: 12rpx;
}

.note-card {
  overflow: hidden;
  border-radius: 14rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(36, 43, 46, 0.08);
}

.note-cover-wrap {
  position: relative;
  height: 330rpx;
  background: #e8ece8;
}

.note-card.tall .note-cover-wrap {
  height: 420rpx;
}

.note-card.short .note-cover-wrap {
  height: 258rpx;
}

.note-cover {
  width: 100%;
  height: 100%;
}

.note-cover-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 52rpx 18rpx 18rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.62));
}

.note-cover-text {
  color: #fffdf7;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.18;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.28);
}

.note-body {
  padding: 16rpx 16rpx 18rpx;
}

.note-title {
  display: -webkit-box;
  overflow: hidden;
  color: #242b2e;
  font-size: 28rpx;
  font-weight: 850;
  line-height: 1.35;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.note-desc {
  display: -webkit-box;
  margin-top: 8rpx;
  overflow: hidden;
  color: #697174;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.36;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.note-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
}

.note-author {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 8rpx;
  color: #657174;
  font-size: 21rpx;
  font-weight: 800;
}

.note-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 34rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #242b2e;
  color: #fffdf7;
  font-size: 18rpx;
  font-weight: 900;
}

.note-author-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.like-button {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 0 0 auto;
  gap: 6rpx;
  color: #687174;
  font-size: 22rpx;
  font-weight: 850;
}

.like-heart {
  font-size: 34rpx;
  line-height: 1;
}

.like-button.liked {
  color: #d82f3f;
}

.ad-card {
  background: #fff7eb;
}

.ad-label {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  z-index: 1;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(36, 43, 46, 0.76);
  color: #fffdf7;
  font-size: 18rpx;
  font-weight: 900;
}

/* Xiaohongshu-style light content surface */
.feed-page {
  min-height: 100vh;
  padding: 0 8rpx 150rpx;
  background: #fffdf7;
  color: #1f2527;
}

.feed-top {
  position: sticky;
  top: 0;
  z-index: 10;
  display: grid;
  grid-template-columns: 76rpx minmax(0, 1fr) 76rpx;
  align-items: center;
  min-height: 96rpx;
  padding: 4rpx 8rpx 0;
  background: rgba(255, 253, 247, 0.98);
  border-bottom: 1rpx solid rgba(31, 37, 39, 0.08);
}

.feed-menu,
.feed-search {
  color: #1f2527;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1;
}

.feed-top-spacer {
  min-height: 1rpx;
}

.feed-tabs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 36rpx;
}

.feed-tab {
  position: relative;
  color: #969a9c;
  font-size: 32rpx;
  font-weight: 850;
  line-height: 1.2;
}

.feed-tab.active {
  color: #1f2527;
}

.feed-tab.active::after {
  content: "";
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: -17rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #d82f3f;
}

.feed-benefit {
  min-height: 56rpx;
  border-radius: 999rpx;
  background: #1f2527;
  color: #fffdf7;
  font-size: 21rpx;
  font-weight: 900;
  padding: 0 14rpx;
}

.feed-cats {
  width: 100%;
  padding: 18rpx 12rpx 12rpx;
  white-space: nowrap;
  background: #fffdf7;
  border-bottom: 1rpx solid rgba(31, 37, 39, 0.06);
}

.feed-cat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  margin-right: 30rpx;
  color: #747b7d;
  font-size: 28rpx;
  font-weight: 800;
}

.feed-cat.active {
  color: #1f2527;
  font-weight: 950;
}

.feed-cat-shell {
  position: relative;
  background: #fffdf7;
  border-bottom: 1rpx solid rgba(31, 37, 39, 0.06);
}

.feed-cat-shell .feed-cats {
  box-sizing: border-box;
  padding: 10rpx 42rpx 8rpx;
  border-bottom: 0;
}

.feed-cat-shell .feed-cat {
  display: inline-flex;
  box-sizing: border-box;
  width: 174rpx;
  min-width: 174rpx;
  max-width: 174rpx;
  min-height: 52rpx;
  margin: 0 12rpx 0 0;
  padding: 0 10rpx;
  border: 0;
  line-height: 52rpx;
  border-radius: 999rpx;
  background: transparent;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  vertical-align: top;
}

.feed-cat-shell .feed-cat::after {
  border: 0;
}

.feed-cat-cue {
  position: absolute;
  top: 50%;
  z-index: 2;
  width: 32rpx;
  height: 44rpx;
  margin-top: -22rpx;
  border-radius: 50%;
  background: rgba(31, 37, 39, 0.12);
  color: #1f2527;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 40rpx;
  text-align: center;
  pointer-events: auto;
}

.feed-cat-cue.left {
  left: 10rpx;
}

.feed-cat-cue.right {
  right: 10rpx;
}

.feed-menu {
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 4rpx;
  border-radius: 18rpx;
}

.side-drawer-layer {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 1000;
  display: flex;
}

.side-drawer-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.58);
}

.side-drawer-panel {
  position: relative;
  z-index: 1;
  width: 560rpx;
  max-width: 76vw;
  min-height: 100vh;
  overflow-y: auto;
  padding: 34rpx 22rpx calc(34rpx + env(safe-area-inset-bottom));
  background: #f6f6f6;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 20rpx 0 44rpx rgba(31, 37, 39, 0.16);
}

.side-drawer-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.side-menu-card {
  overflow: hidden;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(31, 37, 39, 0.035);
}

.side-menu-card.single,
.side-menu-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 0 32rpx;
}

.side-menu-row + .side-menu-row {
  border-top: 1rpx solid rgba(31, 37, 39, 0.06);
}

.side-menu-icon {
  width: 42rpx;
  color: #33383a;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1;
  text-align: center;
}

.side-menu-text {
  color: #4b5052;
  font-size: 30rpx;
  font-weight: 650;
}

.side-menu-bottom {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 4rpx 8rpx;
}

.side-bottom-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  color: #6f7476;
  font-size: 22rpx;
  font-weight: 650;
}

.side-bottom-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eeeeee;
  color: #34393b;
  font-size: 34rpx;
  font-weight: 700;
}

.feed-search-box,
.experience-search {
  margin: 14rpx 8rpx 6rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f2f3f0;
}

.feed-search-box input,
.experience-search input {
  height: 70rpx;
  color: #1f2527;
  font-size: 25rpx;
}

.helper-note {
  margin: 14rpx 8rpx 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 18rpx;
  background: #f5f1e5;
  color: #6a4d00;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.45;
}

