.page-head .h1 {
  font-size: 48rpx;
  line-height: 1.12;
}

.search-panel {
  padding: 12rpx;
  margin: 22rpx 0 18rpx;
}

.search-input {
  width: 100%;
  height: 76rpx;
  padding: 0 18rpx;
  color: #242b2e;
  font-size: 28rpx;
}

.need-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.need-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #fffdf7;
  border: 1rpx solid rgba(36, 43, 46, 0.14);
  color: #242b2e;
  font-size: 24rpx;
  font-weight: 900;
}

.need-chip.active {
  background: #242b2e;
  color: #fffdf7;
}

.need-panel {
  padding: 26rpx;
  margin-bottom: 20rpx;
}

.need-title {
  display: block;
  font-size: 36rpx;
  font-weight: 950;
}

.need-desc {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 253, 247, 0.82);
  font-size: 24rpx;
  font-weight: 700;
}

.need-button {
  width: 220rpx;
  min-height: 60rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #242b2e;
  font-size: 24rpx;
  font-weight: 900;
}

.school-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.school-card {
  display: grid;
  grid-template-columns: 180rpx minmax(0, 1fr);
  overflow: hidden;
  min-height: 190rpx;
  text-align: left;
}

.school-image {
  width: 180rpx;
  height: 100%;
  min-height: 190rpx;
}

.school-body {
  padding: 22rpx;
}

.school-name {
  display: block;
  color: #242b2e;
  font-size: 34rpx;
  font-weight: 950;
}

.school-meta {
  display: block;
  margin: 6rpx 0 14rpx;
  color: #687174;
  font-size: 22rpx;
  font-weight: 800;
}
