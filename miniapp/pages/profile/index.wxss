.page-head .h1 {
  font-size: 46rpx;
  line-height: 1.12;
}

.user-card {
  padding: 30rpx;
  margin-top: 22rpx;
}

.user-name {
  display: block;
  font-size: 42rpx;
  font-weight: 950;
}

.user-meta {
  display: block;
  margin-top: 6rpx;
  color: rgba(255, 253, 247, 0.76);
  font-size: 24rpx;
  font-weight: 700;
}

.points-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.points-grid view {
  padding: 22rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.1);
}

.point-number {
  display: block;
  color: #f8d489;
  font-size: 44rpx;
  font-weight: 950;
}

.point-label {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 253, 247, 0.78);
  font-size: 22rpx;
  font-weight: 800;
}

.settle-note {
  display: block;
  margin-top: 18rpx;
  color: rgba(255, 253, 247, 0.8);
  font-size: 23rpx;
  font-weight: 700;
}

.logout-button {
  min-height: 76rpx;
  margin-top: 22rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 247, 0.14);
  color: #fffdf7;
  font-size: 26rpx;
  font-weight: 900;
}

.login-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 26rpx;
  margin-top: 22rpx;
}

.login-title {
  color: #242b2e;
  font-size: 36rpx;
  font-weight: 950;
}

.login-desc {
  color: #687174;
  font-size: 25rpx;
  font-weight: 750;
  line-height: 1.5;
}

.profile-email-login {
  display: grid;
  gap: 16rpx;
  margin-top: 10rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(36, 43, 46, 0.1);
}

.login-subtitle {
  color: #687174;
  font-size: 24rpx;
  font-weight: 900;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.quick-card {
  min-height: 128rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 950;
}
