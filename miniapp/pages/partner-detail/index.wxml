<view class="partner-detail-page" wx:if="{{merchant}}">
  <view class="merchant-hero {{merchant.level === 'pinned' ? 'is-pinned' : ''}}">
    <view class="merchant-logo">
      <image wx:if="{{merchant.logoImage}}" src="{{merchant.logoImage}}" mode="aspectFill" />
      <text wx:else>{{merchant.logo || merchant.avatar}}</text>
    </view>
    <view class="merchant-hero-copy">
      <text class="merchant-type">{{merchant.type}}</text>
      <text class="merchant-name">{{merchant.author}}</text>
      <text class="merchant-sub">认证商家展示页</text>
    </view>
  </view>

  <view class="merchant-board">
    <image class="merchant-cover" src="{{merchant.image}}" mode="aspectFill" />
    <view class="merchant-board-mask">
      <text class="merchant-board-title">{{merchant.title}}</text>
      <text class="merchant-board-desc">{{merchant.subtitle}}</text>
    </view>
  </view>

  <view class="merchant-tags detail-tags">
    <text wx:for="{{merchant.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
  </view>

  <view class="edit-preview-note" wx:if="{{editPreview}}">
    <text>小程序端展示预览：品牌装饰、拖拽编辑和素材管理仍以网页版后台为准。</text>
    <button bindtap="openWebEditor">复制网页编辑地址</button>
  </view>

  <view class="detail-section-grid">
    <view class="detail-section-card" wx:for="{{merchant.detailSections}}" wx:key="title">
      <text class="section-title">{{item.title}}</text>
      <text class="section-text">{{item.text}}</text>
    </view>
  </view>

  <view class="helper-note">
    <text>商家信息用于帮助学生货比三家。平台展示商家认证、服务边界和咨询入口，不代表平台担保线下交易结果。</text>
  </view>

  <view class="lead-card">
    <text class="lead-title">我要咨询</text>
    <textarea class="textarea" value="{{note}}" bindinput="onNoteInput" placeholder="写下你的学校、城市、预算、时间和想咨询的问题。" />
    <button class="primary-button" bindtap="submitLead">提交咨询意向</button>
    <button class="secondary-button" bindtap="copyContactHint">复制咨询提示</button>
    <button class="secondary-button danger" bindtap="reportMerchant">举报/反馈商家</button>
  </view>
</view>
