.partner-detail-page {
  min-height: 100vh;
  padding: 26rpx 24rpx 48rpx;
  background: #f3f5f1;
}

.merchant-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #fffdf7;
  border: 1rpx solid rgba(36, 43, 46, 0.1);
  box-shadow: 0 18rpx 46rpx rgba(36, 43, 46, 0.08);
}

.merchant-hero.is-pinned {
  border-color: rgba(203, 151, 72, 0.68);
  box-shadow: 0 20rpx 56rpx rgba(203, 151, 72, 0.24);
}

.merchant-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 116rpx;
  height: 116rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #242b2e;
  color: #fffdf7;
  font-size: 38rpx;
  font-weight: 950;
  flex: 0 0 auto;
}

.merchant-logo image {
  width: 100%;
  height: 100%;
}

.merchant-hero-copy {
  min-width: 0;
}

.merchant-type {
  display: block;
  color: #ed573b;
  font-size: 22rpx;
  font-weight: 950;
}

.merchant-name {
  display: block;
  margin-top: 4rpx;
  color: #12345a;
  font-size: 50rpx;
  font-weight: 950;
  line-height: 1.05;
}

.merchant-sub {
  display: block;
  margin-top: 8rpx;
  color: #687174;
  font-size: 23rpx;
  font-weight: 850;
}

.merchant-board {
  position: relative;
  min-height: 380rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 30rpx;
  background: #12345a;
}

.merchant-cover {
  width: 100%;
  height: 420rpx;
  opacity: 0.42;
}

.merchant-board-mask {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  bottom: 28rpx;
}

.merchant-board-title {
  display: block;
  color: #fffdf7;
  font-size: 48rpx;
  font-weight: 950;
  line-height: 1.1;
}

.merchant-board-desc {
  display: block;
  margin-top: 14rpx;
  color: rgba(255,253,247,.86);
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.5;
}

.detail-tags {
  margin: 18rpx 0 0;
}

.merchant-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.merchant-tags text {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(36, 43, 46, 0.08);
  color: #4c5658;
  font-size: 20rpx;
  font-weight: 850;
}

.edit-preview-note,
.helper-note,
.lead-card,
.detail-section-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fffdf7;
  border: 1rpx solid rgba(36, 43, 46, 0.1);
}

.edit-preview-note text,
.helper-note text {
  color: #687174;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.5;
}

.edit-preview-note button {
  min-height: 74rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
  background: #242b2e;
  color: #fffdf7;
  font-size: 26rpx;
  font-weight: 900;
}

.detail-section-grid {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.section-title {
  display: block;
  color: #ed573b;
  font-size: 24rpx;
  font-weight: 950;
}

.section-text {
  display: block;
  margin-top: 12rpx;
  color: #4f5a5d;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.55;
}

.lead-card {
  display: grid;
  gap: 16rpx;
}

.lead-title {
  color: #242b2e;
  font-size: 36rpx;
  font-weight: 950;
}

.secondary-button.danger {
  color: #ed573b;
}
