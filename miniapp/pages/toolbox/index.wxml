  <block wx:if="{{type === 'wallet'}}">
    <view class="menu-hero">
      <text class="eyebrow">钱包</text>
      <text class="menu-title">管理消费积分和可提现积分</text>
      <text class="menu-intro">消费积分用于提问、发帖和解锁内容；可提现积分来自被采纳回答、悬赏任务和付费内容收益。</text>
    </view>
    <view class="wallet-panel">
      <view class="wallet-card dark">
        <text class="wallet-label">消费积分</text>
        <text class="wallet-number">300</text>
        <text class="wallet-desc">用于提问、发布悬赏、解锁资料</text>
      </view>
      <view class="wallet-card gold-card">
        <text class="wallet-label">可提现积分</text>
        <text class="wallet-number">120</text>
        <text class="wallet-desc">沉淀期后可申请提现</text>
      </view>
    </view>
    <view class="menu-actions">
      <button data-label="充值消费积分" bindtap="showTodo">充值消费积分</button>
      <button data-label="申请提现" bindtap="showTodo">申请提现</button>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">提现提醒</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">收益沉淀 7 天后可提现</text>
            <text class="menu-row-desc">通过悬赏赚取的积分需要留出确认期，避免后期退款或纠纷。</text>
          </view>
          <text class="menu-row-meta">平台规则</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">违规内容不产生收益</text>
            <text class="menu-row-desc">代写、非法换汇、虚假材料、欺诈广告等内容会被下架并限制提现。</text>
          </view>
          <text class="menu-row-meta">风控</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'rules'}}">
    <view class="menu-hero">
      <text class="eyebrow">社区公约</text>
      <text class="menu-title">先解决真实问题，再获得收益</text>
      <text class="menu-intro">售业禁止非法换汇、代写代考、伪造材料、骚扰、人身攻击和虚假广告。</text>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">发布规范</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">经验必须可验证、可执行</text>
            <text class="menu-row-desc">写清时间、学校、材料、步骤和风险，不制造焦虑。</text>
          </view>
          <text class="menu-row-meta">内容要求</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">服务必须写清边界</text>
            <text class="menu-row-desc">不得发布代考、代写、伪造材料、换钱换米等违法违规服务。</text>
          </view>
          <text class="menu-row-meta">服务要求</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">商家广告必须可识别</text>
            <text class="menu-row-desc">商家资质、价格区间、联系方式和服务范围要清楚展示。</text>
          </view>
          <text class="menu-row-meta">广告要求</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'help'}}">
    <view class="menu-hero">
      <text class="eyebrow">帮助与客服</text>
      <text class="menu-title">遇到问题先从这里处理</text>
      <text class="menu-intro">账号、积分、悬赏、商家合作和内容举报，都可以从这里提交。</text>
    </view>
    <view class="menu-search">
      <text class="menu-search-icon">搜</text>
      <input value="{{searchValue}}" bindinput="onSearchInput" placeholder="搜：提现、悬赏、举报、商家入驻" />
    </view>
    <view class="menu-actions">
      <button data-label="联系人工客服" bindtap="showTodo">联系人工客服</button>
      <button data-label="提交问题反馈" bindtap="showTodo">提交问题反馈</button>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">常见问题</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">悬赏完成后多久结算？</text>
            <text class="menu-row-desc">委托人确认满意后进入结算，收益积分沉淀 7 天后可提现。</text>
          </view>
          <text class="menu-row-meta">收益</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">付费干货不满意怎么办？</text>
            <text class="menu-row-desc">可以提交申诉，平台根据内容是否能解决问题进行审核。</text>
          </view>
          <text class="menu-row-meta">申诉</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">怎么举报违规换汇广告？</text>
            <text class="menu-row-desc">从帖子右上角或客服页提交，平台会下架并限制账号。</text>
          </view>
          <text class="menu-row-meta">举报</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'settings'}}">
    <view class="menu-hero">
      <text class="eyebrow">设置</text>
      <text class="menu-title">管理账号、安全和通知</text>
      <text class="menu-intro">后续会接入微信授权、邮箱绑定、隐私权限和黑名单管理。</text>
    </view>
    <view class="setting-panel">
      <view class="setting-row" data-field="noticeReply" bindtap="toggleNotice">
        <view>
          <text class="setting-title">新回复通知</text>
          <text class="setting-desc" wx:if="{{noticeReply}}">已开启</text>
          <text class="setting-desc" wx:else>已关闭</text>
        </view>
        <view class="setting-switch on" wx:if="{{noticeReply}}"><view></view></view>
        <view class="setting-switch" wx:else><view></view></view>
      </view>
      <view class="setting-row" data-field="noticeReward" bindtap="toggleNotice">
        <view>
          <text class="setting-title">悬赏状态提醒</text>
          <text class="setting-desc" wx:if="{{noticeReward}}">已开启</text>
          <text class="setting-desc" wx:else>已关闭</text>
        </view>
        <view class="setting-switch on" wx:if="{{noticeReward}}"><view></view></view>
        <view class="setting-switch" wx:else><view></view></view>
      </view>
      <view class="setting-row" data-field="noticeMerchant" bindtap="toggleNotice">
        <view>
          <text class="setting-title">商家福利推荐</text>
          <text class="setting-desc" wx:if="{{noticeMerchant}}">已开启</text>
          <text class="setting-desc" wx:else>已关闭</text>
        </view>
        <view class="setting-switch on" wx:if="{{noticeMerchant}}"><view></view></view>
        <view class="setting-switch" wx:else><view></view></view>
      </view>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">账号与安全</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">绑定邮箱</text>
            <text class="menu-row-desc">用于找回账号、接收验证码和重要通知。</text>
          </view>
          <text class="menu-row-meta">未绑定</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">隐私设置</text>
            <text class="menu-row-desc">控制学校、身份阶段和联系方式的展示范围。</text>
          </view>
          <text class="menu-row-meta">建议检查</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">黑名单管理</text>
            <text class="menu-row-desc">被拉黑用户不能私信或评论你的内容。</text>
          </view>
          <text class="menu-row-meta">0 人</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'history'}}">
    <view class="menu-hero">
      <text class="eyebrow">浏览记录</text>
