<view class="menu-page">
  <block wx:if="{{type === 'menu'}}">
    <view class="menu-hero compact">
      <text class="eyebrow">菜单</text>
      <text class="menu-title">常用功能</text>
      <text class="menu-intro">查看草稿、浏览记录、已购买服务、钱包和平台规则。</text>
    </view>
    <view class="menu-list-card menu-entry-card">
      <view class="menu-list-row" data-type="friends" bindtap="openTool">
