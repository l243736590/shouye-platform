        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'spending'}}">
    <view class="menu-hero">
      <text class="eyebrow">消费记录</text>
      <text class="menu-title">积分和服务消费都在这里</text>
      <text class="menu-intro">用于核对悬赏、付费查看、服务预约和商家福利消费记录。</text>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">本月</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">悬赏问题：租房保证金风险</text>
            <text class="menu-row-desc">支出 160 消费积分。</text>
          </view>
          <text class="menu-row-meta">2026-05-06</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">查看干货：D-10 签证流程</text>
