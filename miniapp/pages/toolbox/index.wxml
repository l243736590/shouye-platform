        </view>
        <text class="menu-row-meta">进入</text>
      </view>
      <view class="menu-list-row" data-type="settings" bindtap="openTool">
        <view class="menu-row-main">
          <text class="menu-row-title">设置</text>
          <text class="menu-row-desc">管理账号、安全和通知。</text>
        </view>
        <text class="menu-row-meta">进入</text>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'friends'}}">
    <view class="menu-hero">
      <text class="eyebrow">添加好友</text>
      <text class="menu-title">找到同校、同城或同需求的人</text>
      <text class="menu-intro">可以通过售业号、学校、昵称或关键词找到可以互相帮助的人。</text>
    </view>
    <view class="menu-search">
      <text class="menu-search-icon">搜</text>
      <input value="{{searchValue}}" bindinput="onSearchInput" placeholder="输入售业号、学校、昵称或关键词" />
    </view>
    <view class="menu-actions">
      <button data-label="复制我的售业号" bindtap="showTodo">复制我的售业号</button>
      <button data-label="生成分享名片" bindtap="showTodo">生成分享名片</button>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">推荐添加</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">同校新生互助群</text>
            <text class="menu-row-desc">按学校和入学阶段推荐，可一起问材料、选课和找房。</text>
          </view>
          <text class="menu-row-meta">新生优先</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">同城生活互助</text>
            <text class="menu-row-desc">找搬家、跑腿、宠物照看、同城取送时更方便。</text>
          </view>
          <text class="menu-row-meta">首尔/京畿</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'drafts'}}">
    <view class="menu-hero">
      <text class="eyebrow">我的草稿</text>
      <text class="menu-title">还没发出的内容先放这里</text>
      <text class="menu-intro">草稿会保存提问、经验和技能服务，发布前可以继续修改。</text>
    </view>
    <view class="menu-actions">
      <button bindtap="goQuestionDraft">继续写提问</button>
      <button bindtap="goPostDraft">继续写经验</button>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">最近草稿</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">D-2 打工许可材料怎么写</text>
            <text class="menu-row-desc">已保存问题详情和悬赏积分，补充学校后可发布。</text>
          </view>
          <text class="menu-row-meta">今天 12:20</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">弘大附近转租避坑清单</text>
            <text class="menu-row-desc">已写摘要，还需要补充图片和合同注意事项。</text>
          </view>
          <text class="menu-row-meta">昨天 22:14</text>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{type === 'services'}}">
    <view class="menu-hero">
      <text class="eyebrow">购买的服务</text>
      <text class="menu-title">你已经下单或预约的帮助</text>
      <text class="menu-intro">包括线上答疑、线下跑腿、商家服务和付费资料，状态会按进度更新。</text>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">进行中</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">语学院报名材料核对</text>
            <text class="menu-row-desc">瓦剌留学，已预约沟通。</text>
          </view>
          <text class="menu-row-meta">待确认</text>
        </view>
        <view class="menu-list-row">
          <view class="menu-row-main">
            <text class="menu-row-title">新村附近看房陪同</text>
            <text class="menu-row-desc">找房服务，线下帮助。</text>
          </view>
          <text class="menu-row-meta">明天 15:00</text>
        </view>
      </view>
    </view>
    <view class="menu-section">
      <text class="menu-section-title">已完成</text>
      <view class="menu-list-card">
        <view class="menu-list-row">
