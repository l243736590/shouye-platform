.menu-page {
  min-height: 100vh;
  padding: 30rpx 26rpx 64rpx;
  background: #fffdf7;
  color: #242b2e;
}

.menu-hero {
  padding: 8rpx 2rpx 22rpx;
}

.menu-title {
  display: block;
  max-width: 640rpx;
  margin-top: 8rpx;
  font-size: 50rpx;
  font-weight: 950;
  line-height: 1.08;
}

.menu-intro {
  display: block;
  margin-top: 18rpx;
  color: #687174;
  font-size: 26rpx;
  font-weight: 750;
  line-height: 1.55;
}

.menu-search {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
  margin: 8rpx 0 22rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f1f3ef;
}

.menu-search-icon {
  color: #242b2e;
  font-size: 34rpx;
  font-weight: 800;
}

.menu-search input {
  flex: 1;
  height: 76rpx;
  color: #242b2e;
  font-size: 26rpx;
}

.menu-actions {
  display: flex;
  gap: 14rpx;
  margin: 18rpx 0 30rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.menu-actions button {
  flex: 0 0 auto;
  min-height: 68rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #242b2e;
  color: #fffdf7;
  font-size: 25rpx;
  font-weight: 900;
}

.wallet-panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin: 10rpx 0 22rpx;
}

.wallet-card {
  min-height: 190rpx;
  padding: 24rpx;
  border-radius: 24rpx;
}

.wallet-card.dark {
  background: #242b2e;
  color: #fffdf7;
}

.wallet-card.gold-card {
  background: #c99b2b;
  color: #fffdf7;
}

.wallet-label,
.wallet-desc {
  display: block;
  font-size: 23rpx;
  font-weight: 800;
  opacity: 0.82;
}

.wallet-number {
  display: block;
  margin: 8rpx 0;
  font-size: 54rpx;
  font-weight: 950;
  line-height: 1;
}

.setting-panel {
  overflow: hidden;
  margin: 10rpx 0 22rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(36, 43, 46, 0.08);
}

.setting-row {
  min-height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
}

.setting-row + .setting-row {
  border-top: 1rpx solid rgba(36, 43, 46, 0.06);
}

.setting-title,
.setting-desc {
  display: block;
}

.setting-title {
  font-size: 28rpx;
  font-weight: 900;
}

.setting-desc {
  margin-top: 4rpx;
  color: #7b8587;
  font-size: 22rpx;
  font-weight: 750;
}

.setting-switch {
  width: 86rpx;
  height: 48rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #d9ddd7;
}

.setting-switch view {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ffffff;
  transition: transform 0.18s ease;
}

.setting-switch.on {
  background: #242b2e;
}

.setting-switch.on view {
  transform: translateX(38rpx);
}

.menu-section {
  margin-top: 28rpx;
}

.menu-section-title {
  display: block;
  margin: 0 0 12rpx 4rpx;
  color: #242b2e;
  font-size: 28rpx;
  font-weight: 950;
}

.menu-list-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(36, 43, 46, 0.08);
  box-shadow: 0 12rpx 28rpx rgba(36, 43, 46, 0.045);
}

.menu-list-row {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx;
}

.menu-list-row + .menu-list-row {
  border-top: 1rpx solid rgba(36, 43, 46, 0.06);
}

.menu-row-main {
  min-width: 0;
}

.menu-row-title {
  display: block;
  color: #242b2e;
  font-size: 30rpx;
  font-weight: 950;
  line-height: 1.25;
}

.menu-row-desc {
  display: block;
  margin-top: 8rpx;
  color: #667174;
  font-size: 24rpx;
  font-weight: 720;
  line-height: 1.5;
}

.menu-row-meta {
  flex: 0 0 auto;
  max-width: 150rpx;
  padding-top: 2rpx;
  color: #c99b2b;
  font-size: 22rpx;
  font-weight: 900;
  text-align: right;
}
