<view class="feed-page partner-feed">
  <view class="feed-top">
    <button class="feed-menu" bindtap="openSideMenu">☰</button>
    <view class="feed-tabs">
      <text class="feed-tab" data-tab="关注" bindtap="switchTopTab">关注</text>
      <text class="feed-tab" data-tab="发现" bindtap="switchTopTab">发现</text>
      <text class="feed-tab active" data-tab="商家福利" bindtap="switchTopTab">商家福利</text>
    </view>
  </view>

  <view class="merchant-fishbowl">
    <view class="fishbowl-water"></view>
    <view class="fishbowl-copy">
      <text class="fishbowl-kicker">商家福利总览</text>
      <text class="fishbowl-title">先看入驻商家，再按服务分类刷。</text>
      <text class="fishbowl-desc">点击气泡可进入商家展示页，也可以点下方分类直接看对应类别。</text>
    </view>
    <view
      class="merchant-bubble {{item.bubbleClass}}"
      style="{{item.bubbleStyle}}"
      wx:for="{{fishbowlCards}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="contactMerchant"
    >
      <view class="bubble-logo">
        <image wx:if="{{item.logoImage}}" src="{{item.logoImage}}" mode="aspectFill" />
        <text wx:else>{{item.logo}}</text>
      </view>
      <view class="bubble-copy">
        <text class="bubble-name">{{item.author}}</text>
        <text class="bubble-type">{{item.type}}</text>
      </view>
    </view>
    <view class="fish-category-row">
      <button
        wx:for="{{fishCategoryTabs}}"
        wx:key="*this"
        data-type="{{item}}"
        bindtap="chooseFishCategory"
      >
        {{item}} →
      </button>
    </view>
  </view>

  <view class="feed-cat-shell">
    <view class="feed-cat-cue left" wx:if="{{showLeftCatCue}}" bindtap="scrollCatsLeft">‹</view>
    <scroll-view class="feed-cats" scroll-x enable-flex enhanced show-scrollbar="{{false}}" scroll-left="{{catScrollLeft}}" bindscroll="onCatScroll">
      <button class="feed-cat {{item.className}}" wx:for="{{categoryTabs}}" wx:key="name" data-name="{{item.name}}" bindtap="chooseCategory">{{item.name}}</button>
    </scroll-view>
    <view class="feed-cat-cue right" bindtap="scrollCatsRight">›</view>
  </view>

  <view class="feed-search-box">
    <input value="{{searchValue}}" bindinput="onSearchInput" placeholder="搜：论文、作品集、找房、手机卡、D-10..." />
  </view>

  <view class="feed-grid">
    <view class="note-card {{item.className}} ad-card {{item.level === 'pinned' ? 'pinned-card' : ''}}" wx:for="{{visibleCards}}" wx:key="id" data-id="{{item.id}}" bindtap="contactMerchant">
      <view class="note-cover-wrap">
        <text class="ad-label">{{item.type}}</text>
        <image class="note-cover" src="{{item.image}}" mode="aspectFill" lazy-load="true" />
        <view class="note-cover-mask">
          <text class="note-cover-text">{{item.title}}</text>
        </view>
      </view>
      <view class="note-body">
        <text class="note-title">{{item.title}}</text>
        <text class="note-desc">{{item.subtitle}}</text>
        <view class="merchant-tags">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
        <view class="note-meta-row">
          <view class="note-author">
            <text class="note-avatar">{{item.avatar}}</text>
            <text class="note-author-name">{{item.author}}</text>
          </view>
          <button class="like-button {{item.liked ? 'liked' : ''}}" data-id="{{item.id}}" catchtap="likeItem">
            <text class="like-heart">{{item.liked ? '♥' : '♡'}}</text>
            <text>{{item.likes}}</text>
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
