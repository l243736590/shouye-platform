<template name="sideMenu">
  <view class="side-drawer-layer">
    <view class="side-drawer-mask" catchtap="closeSideMenu"></view>
    <view class="side-drawer-panel" catchtap="stopSideMenu">
      <view class="side-drawer-list">
        <view class="side-menu-card single" data-label="添加好友" catchtap="handleSideMenuAction">
          <text class="side-menu-icon">＋</text>
          <text class="side-menu-text">添加好友</text>
        </view>

        <view class="side-menu-card">
          <view class="side-menu-row" data-label="我的草稿" catchtap="handleSideMenuAction">
            <text class="side-menu-icon">▱</text>
            <text class="side-menu-text">我的草稿</text>
          </view>
          <view class="side-menu-row" data-label="浏览记录" catchtap="handleSideMenuAction">
            <text class="side-menu-icon">◷</text>
            <text class="side-menu-text">浏览记录</text>
          </view>
        </view>

        <view class="side-menu-card">
          <view class="side-menu-row" data-label="购买的服务" catchtap="handleSideMenuAction">
            <text class="side-menu-icon">▤</text>
            <text class="side-menu-text">购买的服务</text>
          </view>
          <view class="side-menu-row" data-label="消费记录" catchtap="handleSideMenuAction">
            <text class="side-menu-icon">◇</text>
            <text class="side-menu-text">消费记录</text>
          </view>
          <view class="side-menu-row" data-label="钱包" catchtap="handleSideMenuAction">
            <text class="side-menu-icon">▣</text>
            <text class="side-menu-text">钱包</text>
          </view>
        </view>

        <view class="side-menu-card single" data-label="社区公约" catchtap="handleSideMenuAction">
          <text class="side-menu-icon">♧</text>
          <text class="side-menu-text">社区公约</text>
        </view>
      </view>

      <view class="side-menu-bottom">
        <view class="side-bottom-item" data-label="扫一扫" catchtap="handleSideMenuAction">
          <view class="side-bottom-icon">⌗</view>
          <text>扫一扫</text>
        </view>
        <view class="side-bottom-item" data-label="帮助与客服" catchtap="handleSideMenuAction">
          <view class="side-bottom-icon">？</view>
          <text>帮助与客服</text>
        </view>
        <view class="side-bottom-item" data-label="设置" catchtap="handleSideMenuAction">
          <view class="side-bottom-icon">⚙</view>
          <text>设置</text>
        </view>
      </view>
    </view>
  </view>
</template>
